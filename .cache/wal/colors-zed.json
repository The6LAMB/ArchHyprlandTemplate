{
    "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
    "name": "pywal",
    "author": "pywal",
    "themes": [
        {
            "name": "pywal",
            "appearance": "dark",
            "style": {
                "background": "#0d061090",
                "editor.background": "#0d061090",
                "editor.foreground": "#c2c0c3",
                "text": "#c2c0c3",
                "text.muted": "#c2c0c370",
                "text.ignored": "#c2c0c340",
                "text.placeholder": "#c2c0c350",
                "ignored": "#c2c0c330",
                "element.hover": "#c2c0c330",
                "ghost_element.hover": "#E8E63F30",
                "ghost_element.selected": "#E8E63F30",
                "ghost_element.active": "#E8E63F60",
                "border": "#0d0610",
                "editor.highlighted_line.background": "#E8E63F10",
                "editor.active_line.background": "#E8E63F10",
                "panel.background": "#0d061090",
                "title_bar.background": "#0d061090",
                "title_bar.inactive_background": "#0d061090",
                "status_bar.background": "#0d061090",
                "drop_target.background": "#0d061090",
                "elevated_surface.background": "#0d0610",
                "toolbar.background": "#0d061090",
                "tab_bar.background": "#0d061090",
                "tab.inactive_background": "#0d061090",
                "tab.active_background": "#E8E63F30",
                "scrollbar.track.background": "transparent",
                "scrollbar.track.border": "#0d0610",
                "scrollbar.thumb.background": "#E8E63F",
                "editor.gutter.background": "#0d061090",
                "terminal.background": "#0d061010",
                "terminal.foreground": "#c2c0c3",
                "terminal.dim_foreground": "#c2c0c3",
                "terminal.bright_foreground": "#c2c0c3",
                "terminal.ansi.black": "#0d0610",
                "terminal.ansi.red": "#E8E63F",
                "terminal.ansi.green": "#9A906D",
                "terminal.ansi.yellow": "#4D8699",
                "terminal.ansi.blue": "#A8AB92",
                "terminal.ansi.magenta": "#B9C2A9",
                "terminal.ansi.cyan": "#DDD3B1",
                "terminal.ansi.white": "#c2c0c3",
                "terminal.ansi.bright_black": "#635669",
                "terminal.ansi.bright_red": "#E8E63F",
                "terminal.ansi.bright_green": "#9A906D",
                "terminal.ansi.bright_yellow": "#4D8699",
                "terminal.ansi.bright_blue": "#A8AB92",
                "terminal.ansi.bright_magenta": "#B9C2A9",
                "terminal.ansi.bright_cyan": "#DDD3B1",
                "terminal.ansi.bright_white": "#c2c0c3",
                "modified": "#E8E63F",
                "syntax": {
                    "attribute": {
                        "color": "#E8E63F"
                    },
                    "boolean": {
                      "color": "#9A906D"
                    },
                    "comment": {
                      "color": "#635669"
                    },
                    "comment.doc": {
                      "color": "#635669"
                    },
                    "constant": {
                      "color": "#9A906D"
                    },
                    "function": {
                      "color": "#DDD3B1"
                    },
                    "keyword": {
                      "color": "#A8AB92"
                    },
                    "number": {
                      "color": "#B9C2A9"
                    },
                    "operator": {
                      "color": "#A8AB92"
                    },
                    "string": {
                      "color": "#E8E63F"
                    },
                    "variable": {
                      "color": "#9A906D"
                    }
                },
                "players": [
                  {
                    "cursor": "#E8E63F",
                    "background": "#0d0610",
                    "selection": "#E8E63F30"
                  }
                ]
            }
        }
    ]
}
